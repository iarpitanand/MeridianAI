# ---- GitHub App (create at https://github.com/settings/apps/new) ----
APP_ID=
# Paste the full PEM. In .env, keep it on one line with \n for newlines,
# or use a quoted multi-line value. Probot also accepts a PRIVATE_KEY_PATH.
PRIVATE_KEY=
WEBHOOK_SECRET=
# Optional (only needed for dashboard "Sign in with GitHub" later)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Dashboard (Sign in with GitHub + Connect repos) ----
# Public base URL of this server (used to build the OAuth redirect_uri and
# the GitHub App's Setup URL target). https:// in prod so session cookies
# get Secure; http://localhost:3000 is fine for local dev.
APP_BASE_URL=http://localhost:3000
# URL slug of your GitHub App, e.g. "meridianaiddev" -> github.com/apps/meridianaiddev
GITHUB_APP_SLUG=
# 32 random bytes, base64-encoded (e.g. `openssl rand -base64 32`).
# Encrypts GitHub user access/refresh tokens at rest (AES-256-GCM).
TOKEN_ENCRYPTION_KEY=

# ---- Postgres (Neon) ----
# e.g. postgresql://user:pass@ep-xxx.region.aws.neon.tech/meridian?sslmode=require
DATABASE_URL=

# ---- Redis (for BullMQ queue) ----
# e.g. redis://default:pass@host:6379  (or rediss:// for TLS)
REDIS_URL=

# ---- Embeddings (optional) ----
# Without a key, indexing still builds the call graph (symbols + refs);
# semantic search is simply disabled until you add one.
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-code-3
EMBEDDING_DIMENSIONS=1024

# ---- Indexing ----
INDEX_CONCURRENCY=8
INDEX_MAX_FILE_BYTES=300000

# ---- LLM review (optional) ----
# Without a key, reviews still post (change-size summary only); no inline analysis.
ANTHROPIC_API_KEY=
REVIEW_MODEL=claude-sonnet-5
CRITIC_MODEL=claude-haiku-4-5-20251001

# ---- Linear requirements check (optional) ----
# Without a key, this feature is skipped entirely; the normal review is unaffected.
# When a PR body contains `id: "TEAM-123"`, fetches that Linear issue and posts
# a separate pass/fail comment checking the diff against its description.
LINEAR_API_KEY=

# ---- Runtime ----
PORT=3000
REVIEW_DEBOUNCE_MS=75000
LOG_LEVEL=info
